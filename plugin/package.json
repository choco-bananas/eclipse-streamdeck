{
  "name": "com.mtcjapan.eclipsehci",
  "version": "1.0.0",
  "description": "Clear-Com Eclipse HCI controller for Stream Deck",
  "main": "src/plugin.ts",
  "scripts": {
    "build": "npm run build:plugin && npm run build:bridge",
    "build:plugin": "rollup -c rollup.config.mjs",
    "build:bridge": "tsc -p tsconfig.bridge.json",
    "watch": "rollup -c rollup.config.mjs --watch",
    "dev": "streamdeck dev"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "rollup": "^4.27.3",
    "tslib": "^2.8.1",
    "typescript": "^5.7.0"
  }
}
